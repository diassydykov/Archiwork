# Карты: osm (бесплатно, по умолчанию) или google (нужен биллинг)
NEXT_PUBLIC_MAP_PROVIDER=osm
# Google Maps (только если NEXT_PUBLIC_MAP_PROVIDER=google)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_API_KEY=

# Image generation
LEONARDO_API_KEY=
STABILITY_API_KEY=

# Alem LLM (Qwen — ассистент, спецификация, запасной улучшатель промптов)
ALEM_LLM_URL=https://llm.alem.ai
QWEN_API_KEY=

# xAI Grok — улучшение промптов + генерация картинок (Grok Imagine)
GROK_API_KEY=
# GROK_MODEL=grok-3-mini
# GROK_IMAGE_MODEL=grok-imagine-image
# GROK_IMAGE_MODEL_QUALITY=grok-imagine-image-quality
# IMAGE_PROMPT_LLM=grok

# Alem LLM (Deepseek OCR — распознавание планов, позже)
DEEPSEEK_OCR_API_KEY=

# MinIO / S3 (хранение сгенерированных изображений)
S3_ENDPOINT=https://a1-s3-1.alem.ai
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_PUBLIC_URL=https://a1-s3-1.alem.ai

# PostgreSQL (база пользователей и проектов, позже)
DATABASE_URL=postgresql://user:password@host:port/dbname

# Langflow (визуальные AI-пайплайны, опционально)
LANGFLOW_URL=
